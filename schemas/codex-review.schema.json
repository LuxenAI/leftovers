{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Leftovers Codex review result",
  "type": "object",
  "required": ["verdict", "findings", "missing_verification", "pr_claims_supported"],
  "properties": {
    "verdict": { "enum": ["approve", "revise", "abandon"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "summary", "evidence", "path"],
        "properties": {
          "severity": { "enum": ["blocker", "major", "minor"] },
          "summary": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "path": { "type": ["string", "null"], "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "missing_verification": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "pr_claims_supported": { "type": "boolean" }
  },
  "additionalProperties": false
}
