# Copy this file to .leftovers/scheduler.env, replace absolute paths, and chmod it 0600.
# Values are literal text after the first '='. Quotes and shell expansion are not interpreted.
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
LEFTOVERS_PYTHON=/ABSOLUTE/PATH/TO/python3
LEFTOVERS_CONFIG=/ABSOLUTE/PATH/TO/Leftovers/config/leftovers.toml
LEFTOVERS_LOCK_FILE=/ABSOLUTE/PATH/TO/Leftovers/.leftovers/run.lock
LEFTOVERS_PUBLISH=0

# Add only controller credentials needed by your deployment. Never commit the populated file.
# A read-only discovery token may use the configured github.token_env name.
# GITHUB_TOKEN=
# Provider-specific variables are passed to the worker only when explicitly listed in
# agent.pass_environment; GitHub credentials and runtime sockets are rejected by config validation.
